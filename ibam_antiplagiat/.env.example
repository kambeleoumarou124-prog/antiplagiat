# Django
DJANGO_SECRET_KEY=<générer avec python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
DEBUG=False
ALLOWED_HOSTS=localhost,antiplagiat.ibam.bf

# Base de données PostgreSQL
POSTGRES_DB=ibam_antiplagiat
POSTGRES_USER=ibam_user
POSTGRES_PASSWORD=Oumarou#1@
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=<générer avec python -c "import secrets; print(secrets.token_hex(32))">

# Email SMTP
SMTP_HOST=smtp.ibam.bf
SMTP_PORT=587
SMTP_USER=noreply@ibam.bf
SMTP_PASSWORD=<password>

# Stockage
STORAGE_BASE_PATH=/var/ibam/storage

# NLP
NLP_TIMEOUT_SECONDS=300
NLP_SEUIL_COSINUS=0.60

# Sécurité
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_MINUTES=15
RESET_PASSWORD_EXPIRE_HOURS=24
SIGNATURE_MAX_ATTEMPTS=3
SIGNATURE_LOCKOUT_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://antiplagiat.ibam.bf
